# ===== TEKNOPLAST — Production (VPS) sozlamalari =====
# Bu faylni VPS'da `.env` deb nusxalang va qiymatlarni to'ldiring.

NODE_ENV=production
PORT=5000

# --- Baza: SQLite (tavsiya, oddiy) ---
# USE_POSTGRES o'rnatilmasa SQLite ishlatiladi. Fayl: backend/teknoplast.sqlite
USE_POSTGRES=false

# --- Agar keyinroq PostgreSQL'ga o'tsangiz ---
# USE_POSTGRES=true
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=teknoplast
# DB_USER=teknoplast
# DB_PASSWORD=BU_YERGA_KUCHLI_PAROL

# --- JWT maxfiy kalit (MUHIM: o'zgartiring!) ---
# Yangi kalit yaratish: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=BU_YERGA_96_BELGILI_TASODIFIY_HEX

# --- AI (ixtiyoriy, Claude API) ---
ANTHROPIC_API_KEY=

# --- Frontend manzili (CORS uchun, sizning domeningiz) ---
FRONTEND_URL=https://teknoplast.uz
