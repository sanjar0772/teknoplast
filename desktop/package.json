{
  "name": "teknoplast-desktop",
  "version": "1.0.0",
  "description": "TEKNOPLAST — Windows ish stoli ilovasi",
  "main": "main.js",
  "author": "Teknoplast",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --publish never"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "uz.teknoplast.app",
    "productName": "TEKNOPLAST",
    "asar": true,
    "publish": null,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TEKNOPLAST"
    }
  }
}
